# =============================================
# Redis Configuration
# =============================================
# Set REDIS_URL to use Redis storage instead of in-memory.
# If empty or omitted, the backend falls back to in-memory storage.
#
# Formats:
#   redis://host:port                  (no auth)
#   redis://username:password@host:port (with auth)
#   redis://:password@host:port        (password only)
#   rediss://host:port                 (TLS/SSL)
#
# Managed Redis services (Upstash, Redis Cloud, AWS ElastiCache, etc.)
# typically provide a full connection URL that already includes auth.
#
# Self-hosted Redis without auth:
#   REDIS_URL=redis://localhost:6379
#
# With password:
#   REDIS_URL=redis://:yourpassword@your-redis-host:6379
#
# With TLS (recommended for production):
#   REDIS_URL=rediss://your-redis-host:6379
#
# Leave empty to use in-memory storage (ephemeral, data lost on restart):
REDIS_URL=
