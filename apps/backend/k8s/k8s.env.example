# Cloudflare Tunnel environment variables
# Copy this file to k8s.env and fill in your values
# DO NOT commit k8s.env to version control

# Tunnel UUID (e.g., 123e4567-e89b-12d3-a456-426614174000)
TUNNEL_UUID=

# Public hostname for the tunnel (e.g., subdomain.example.com)
TUNNEL_HOSTNAME=

# Tunnel name (e.g., partybooster-hpe)
TUNNEL_NAME=partybooster-hpe